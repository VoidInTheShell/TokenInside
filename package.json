    "db:verify-import": "node scripts/db-verify-import.mjs",
    "quota:risk-scan": "node scripts/quota-risk-scan.mjs",
    "quota:migrate": "node scripts/quota-ledger-migrate.mjs",
    "f:db-check": "node scripts/f-stage-db-check.mjs",
    "f:lock-check": "node scripts/f-stage-lock-check.mjs",
    "f:gateway-load-check": "node scripts/gateway-concurrency-check.mjs",
    "f:newapi-control-load-check": "node scripts/newapi-control-concurrency-check.mjs",
    "f:app-check": "node scripts/f-stage-app-check.mjs",
