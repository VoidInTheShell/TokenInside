{
  "name": "tokeninside",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test tests/*.test.ts",
    "dev": "next dev --hostname 127.0.0.1 --port 16878",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 16878",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node scripts/db-migrate.mjs",
    "g:db-check": "node scripts/g-stage/g-stage-db-check.mjs",
    "g:app-check": "node scripts/g-stage/g-stage-app-check.mjs",
    "g:race-check": "node scripts/g-stage/g-stage-race-check.mjs",
    "g:audit-check": "node scripts/g-stage/g-stage-audit-check.mjs",
    "g:load-check": "node scripts/g-stage/g-stage-load-check.mjs",
    "production:preflight": "node scripts/production-preflight.mjs",
    "production:pg-backup": "bash scripts/production-pg-backup.sh",
    "production:pg-restore": "bash scripts/production-pg-restore.sh",
    "production:docker-pull": "bash scripts/production-docker-pull-with-mihomo.sh"
  },
  "dependencies": {
    "@radix-ui/react-progress": "^1.1.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^16.0.0",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "redis": "^6.1.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
