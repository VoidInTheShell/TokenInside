# TokenInside compose deployment example.
# Copy this file to `.env`, fill every `replace-with-*` value, then run:
#   docker compose -f docker-compose.example.yml up -d
#   docker compose -f docker-compose.example.yml exec tokeninside npm run db:migrate

# Runtime
NODE_ENV=production
HOSTNAME=0.0.0.0
PORT=16878
NEXT_TELEMETRY_DISABLED=1

# Public control-plane URL.
# This must be the HTTPS URL users open in Feishu and the URL configured in Feishu H5 trusted domain / redirect settings.
TOKENINSIDE_PUBLIC_BASE_URL=https://ti.example.com

# Required for signed Feishu session cookies.
# Use a long random value; for example: `openssl rand -base64 48`.
TOKENINSIDE_SESSION_SECRET=replace-with-a-long-random-session-secret

# Storage
# Compose deployments should use PostgreSQL. JSON is only for local throwaway testing.
TOKENINSIDE_STORE_BACKEND=postgres

# Used only when TOKENINSIDE_STORE_BACKEND=json.
TOKENINSIDE_STORE_PATH=.local-data/tokeninside.json

# PostgreSQL connection used by the app container.
# `postgres` is the service name in docker-compose.example.yml.
POSTGRES_DB=tokeninside
POSTGRES_USER=tokeninside
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
DATABASE_URL=postgresql://tokeninside:replace-with-a-strong-postgres-password@postgres:5432/tokeninside

# PostgreSQL app pool defaults for a small 2C2G host.
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=5000

# Feishu application
# Create a self-built Feishu app, enable H5 / web entry, robot messaging, contact read scopes, and card callback events.
FEISHU_APP_ID=replace-with-feishu-app-id
FEISHU_APP_SECRET=replace-with-feishu-app-secret

# Feishu approval / card callback settings.
# The current MVP uses interactive cards as the main approval path.
# Keep the approval code if you also keep the legacy Feishu approval-instance fallback configured.
FEISHU_APPROVAL_CODE_TOKEN_REQUEST=replace-with-approval-code-or-leave-empty
FEISHU_APPROVAL_EVENT_VERIFICATION_TOKEN=replace-with-feishu-event-verification-token
FEISHU_APPROVAL_EVENT_ENCRYPT_KEY=replace-with-feishu-event-encrypt-key

# Optional comma-separated Feishu open_id allowlist for global TokenInside administrators.
# This is authorization after Feishu OAuth, not a new authentication method.
# Example: TOKENINSIDE_ADMIN_OPEN_IDS=ou_xxx,ou_yyy
TOKENINSIDE_ADMIN_OPEN_IDS=

# NewAPI endpoint and server-side control credentials.
# Keep all values server-side only. Do not expose them in the frontend.
NEWAPI_BASE_URL=https://new-api.example.com

# Required by the NewAPI user-scoped `/api/token` control APIs.
NEWAPI_CONTROL_USER_ID=replace-with-newapi-control-user-id

# Provide the credential type your NewAPI deployment accepts.
# The current test deployment supports System AK; leave unused credential fields empty.
NEWAPI_SYSTEM_AK=replace-with-newapi-system-ak
NEWAPI_ACCESS_TOKEN=
NEWAPI_ADMIN_ACCESS_TOKEN=

# NewAPI internal quota unit multiplier. Upstream default is 500000 quota per 1 display unit.
NEWAPI_QUOTA_PER_UNIT=500000

# Monthly billing reset is disabled by default.
# Enable only after PostgreSQL backup/restore and operational checks are in place.
TOKENINSIDE_MONTHLY_RESET_ENABLED=false

# Local-only integration switch. Leave false outside local throwaway testing.
TOKENINSIDE_MOCK_NEWAPI=false
