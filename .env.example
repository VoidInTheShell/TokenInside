# TokenInside 部署环境变量示例。
# 用法：
# 1. 复制本文件为 `.env`。
# 2. 按下面每一项中文说明填写 `replace-with-*` 或空值。
# 3. 启动：
#    docker compose -f docker-compose.example.yml up -d
#    docker compose -f docker-compose.example.yml exec tokeninside npm run db:migrate

# 运行环境：生产部署固定写 production。
NODE_ENV=production

# 监听地址：容器内需要监听 0.0.0.0，便于 Docker / 反代访问。
HOSTNAME=0.0.0.0

# TokenInside 应用容器监听端口。
# 获取方式：按部署规划填写；当前项目默认服务端口为 16878。
PORT=16878

# 是否关闭 Next.js telemetry。生产建议保持 1。
NEXT_TELEMETRY_DISABLED=1

# TokenInside 应用镜像：CI/CD 默认发布到 GitHub Container Registry。
# staging 通常使用 ghcr.io/voidintheshell/tokeninside:staging；
# production 通常使用 ghcr.io/voidintheshell/tokeninside:production；
# 回滚或精确部署时使用 ghcr.io/voidintheshell/tokeninside:sha-<commit>。
TOKENINSIDE_IMAGE=ghcr.io/voidintheshell/tokeninside:staging

# TokenInside 对外访问地址。
# 用途：生成 OAuth 回调、前端 Base URL、飞书网页入口和卡片跳转等公开链接。
# 获取方式：填写已经完成 HTTPS 反代并配置到飞书后台的公网域名，例如 https://tokeninside.example.com。
# 注意：必须和飞书开放平台里的网页应用主页、移动端主页、H5 可信域名、重定向 URL 所属域名一致。
TOKENINSIDE_PUBLIC_BASE_URL=https://ti.example.com

# 会话签名密钥。
# 用途：签名 TokenInside 自己的飞书登录 session cookie。
# 获取方式：自行生成长随机字符串，例如在 Linux/WSL/服务器执行 `openssl rand -base64 48`。
# 注意：生产环境必须固定保存；更换后现有登录态会失效。不要提交真实值。
TOKENINSIDE_SESSION_SECRET=replace-with-a-long-random-session-secret

# 存储后端。
# 用途：决定 TokenInside 状态存储在 PostgreSQL 还是本地 JSON 文件。
# 获取方式：生产/compose 部署填写 postgres；本地一次性临时测试可填 json。
TOKENINSIDE_STORE_BACKEND=postgres

# JSON 存储文件路径。
# 用途：仅在 TOKENINSIDE_STORE_BACKEND=json 时使用。
# 获取方式：本地测试可保持默认；生产使用 postgres 时不会使用该文件。
TOKENINSIDE_STORE_PATH=.local-data/tokeninside.json

# PostgreSQL 数据库名。
# 用途：给 docker-compose.example.yml 中的 postgres 服务初始化数据库。
# 获取方式：自定义，保持与 DATABASE_URL 中路径一致即可。
POSTGRES_DB=tokeninside

# PostgreSQL 用户名。
# 用途：给 postgres 服务初始化数据库用户，并供 TokenInside 连接数据库。
# 获取方式：自定义，保持与 DATABASE_URL 中用户名一致即可。
POSTGRES_USER=tokeninside

# PostgreSQL 密码。
# 用途：数据库连接密码。
# 获取方式：自行生成强随机密码；例如 `openssl rand -base64 32`。不要使用示例值。
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

# TokenInside 应用连接 PostgreSQL 的完整连接串。
# 用途：应用容器读取/写入 PostgreSQL。
# 获取方式：按 POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB 拼接。
# 注意：在 docker-compose.example.yml 中，主机名 `postgres` 是 compose 服务名，不是公网地址。
DATABASE_URL=postgresql://tokeninside:replace-with-a-strong-postgres-password@postgres:5432/tokeninside

# PostgreSQL 应用连接池最大连接数。
# 用途：限制 Next.js 应用占用的数据库连接数。
# G 阶段 960 并发实测值为 256；若目标机内存不足，只能在重新跑完同等账本验收后下调。
DATABASE_POOL_MAX=256

# PostgreSQL advisory session lock 专用连接池。
# 用途：避免额度/同步锁与 API 业务查询在同一个连接池中形成循环等待。
DATABASE_LOCK_POOL_MAX=64

# PostgreSQL 空闲连接保留时间，单位毫秒。
# 用途：释放长期空闲连接。
# 获取方式：默认 30000 即可。
DATABASE_POOL_IDLE_TIMEOUT_MS=30000

# PostgreSQL 建连超时，单位毫秒。
# 用途：数据库不可用时快速失败。
# 960 并发下 5000 会造成连接获取超时；本轮实测采用 30000。
DATABASE_POOL_CONNECTION_TIMEOUT_MS=30000

# TokenInside Redis 热路径缓存与跨实例协调；生产 Compose 使用内部服务名 redis。
TOKENINSIDE_REDIS_URL=redis://redis:6379/0
# 生产/验收要求 Redis 不可缺失；故障时 health 返回 degraded，读路径仍回退 PostgreSQL。
TOKENINSIDE_REDIS_REQUIRED=true
# 多环境共用 Redis 时必须使用不同前缀。
TOKENINSIDE_REDIS_KEY_PREFIX=tokeninside
# Key -> TokenAccount -> 飞书用户热缓存 TTL；禁用/换 Key 路径会主动失效。
TOKENINSIDE_REDIS_PRINCIPAL_TTL_SECONDS=300
TOKENINSIDE_REDIS_CONNECT_TIMEOUT_MS=1000

# TokenInside 同时放行到 NewAPI 的长连接代理请求数。
# G 阶段 120 用户 x 8 = 960 已实测通过，保持 960。
TOKENINSIDE_PROXY_CONCURRENCY_MAX=960

# 用户请求队列容量。0 表示槽位满时立即返回可重试 503，禁止等待影响首字延迟。
TOKENINSIDE_PROXY_QUEUE_MAX=0

# 仅在队列容量大于 0 时生效；等待上游槽位的最长时间，单位毫秒。
TOKENINSIDE_PROXY_QUEUE_TIMEOUT_MS=30000

# 数据库前置准备阶段（Key/用户/额度准入/proxy log）的独立短时并发上限。
# 为避免应用准备闸门拒绝 960 突发，本轮实测值为 960；实际 PG 写入仍由业务连接池背压。
TOKENINSIDE_PROXY_PREPARATION_CONCURRENCY_MAX=960

# 用户请求的数据库准备队列容量。0 表示准备槽位满时立即失败，不在应用内排队。
TOKENINSIDE_PROXY_PREPARATION_QUEUE_MAX=0

# 仅在准备队列容量大于 0 时生效；超时返回带 Retry-After 与结构化错误体的 503。
TOKENINSIDE_PROXY_PREPARATION_QUEUE_TIMEOUT_MS=30000

# 仅在尚未向客户端发送响应字节时，对 NewAPI 网络错误/408/429/5xx 做有限重试。
TOKENINSIDE_PROXY_UPSTREAM_MAX_ATTEMPTS=2
TOKENINSIDE_PROXY_UPSTREAM_RETRY_BASE_MS=250
TOKENINSIDE_PROXY_UPSTREAM_RETRY_MAX_DELAY_MS=2000

# PostgreSQL / TokenInside 调优参数。
# 简单判断方法：
# 1. 本区数值来自本地 960/960、账本无失真的验收；LA 2C2G 仍需以容器 OOM/重启和公网 960 验收复核。
# 2. 如果 /api/health、日志或压测出现 pool timeout，再小幅增加连接池；多 app 副本时按副本数累加，确保 (业务池 + 锁池) × 副本数 + 5 个维护余量 < POSTGRES_MAX_CONNECTIONS - POSTGRES_SUPERUSER_RESERVED_CONNECTIONS。
# 3. 如果 PG 容器 OOM 或频繁重启，优先降低 DATABASE_POOL_MAX、POSTGRES_WORK_MEM 或 POSTGRES_SHARED_BUFFERS，不要同时增加连接数和 work_mem。
# 4. 如果慢查询增多，先看 POSTGRES_LOG_MIN_DURATION_STATEMENT 打出的 SQL、索引和 NewAPI 上游等待，不要直接加连接数。
# 5. 如果写入后表膨胀、vacuum 跟不上，再调 autovacuum_*；不要关闭 POSTGRES_AUTOVACUUM。

# PostgreSQL 总连接上限；需要覆盖 app pool、维护连接和超级用户预留连接。
POSTGRES_MAX_CONNECTIONS=400
# PostgreSQL 超级用户和维护操作预留连接；不要分配给应用池。
POSTGRES_SUPERUSER_RESERVED_CONNECTIONS=3

# PG 共享缓存；当前 PG 容器 768m 内存口径下默认 256MB。
POSTGRES_SHARED_BUFFERS=256MB
# 优化器缓存估算值，不是实际分配内存；通常按 PG 可用内存和系统缓存估算。
POSTGRES_EFFECTIVE_CACHE_SIZE=768MB
# 单个排序 / hash 操作可用内存；连接数升高时不要同步放大该值。
POSTGRES_WORK_MEM=1MB
# vacuum、建索引等维护任务内存。
POSTGRES_MAINTENANCE_WORK_MEM=64MB

# checkpoint 间隔；写入压力不大时保持 10min，过短会增加刷盘频率。
POSTGRES_CHECKPOINT_TIMEOUT=10min
# checkpoint 平滑刷盘比例；0.9 表示尽量把刷盘分散到周期内。
POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
# WAL 最大保留区间；写入突增时可减少 checkpoint 抖动。
POSTGRES_MAX_WAL_SIZE=512MB
# WAL 最小保留区间；低写入量下避免频繁回收和重建。
POSTGRES_MIN_WAL_SIZE=128MB
# WAL buffer；小型单机场景保持 16MB 即可。
POSTGRES_WAL_BUFFERS=16MB
# WAL 压缩；可用少量 CPU 换磁盘写入和存储空间。
POSTGRES_WAL_COMPRESSION=on

# 是否开启 autovacuum；生产必须保持 on。
POSTGRES_AUTOVACUUM=on
# autovacuum worker 数；2C2G 小机器默认 2，CPU 紧张时不要盲目升高。
POSTGRES_AUTOVACUUM_MAX_WORKERS=2
# autovacuum 唤醒间隔；写入/更新较多时可缩短，但会增加后台负载。
POSTGRES_AUTOVACUUM_NAPTIME=30s
# vacuum 触发比例；表膨胀明显时可降低。
POSTGRES_AUTOVACUUM_VACUUM_SCALE_FACTOR=0.05
# analyze 触发比例；查询计划不稳定或数据变化快时可降低。
POSTGRES_AUTOVACUUM_ANALYZE_SCALE_FACTOR=0.02
# vacuum 最低触发行数；小表更新频繁时保持较低值。
POSTGRES_AUTOVACUUM_VACUUM_THRESHOLD=50
# analyze 最低触发行数；小表变化频繁时保持较低值。
POSTGRES_AUTOVACUUM_ANALYZE_THRESHOLD=50

# 空闲事务最长停留时间；用于清理忘记提交/回滚的事务。
POSTGRES_IDLE_IN_TRANSACTION_SESSION_TIMEOUT=30s
# 单条 SQL 最大执行时间；接口型服务默认 30s，避免长查询拖垮连接池。
POSTGRES_STATEMENT_TIMEOUT=30s
# 等锁超时；避免请求长时间卡在锁等待上。
POSTGRES_LOCK_TIMEOUT=5s
# 慢查询日志阈值；排查慢查询时可临时调低，稳定后恢复。
POSTGRES_LOG_MIN_DURATION_STATEMENT=500ms

# PG 容器共享内存大小；过小可能影响并行查询和内存操作。
TOKENINSIDE_POSTGRES_SHM_SIZE=128m
# 以下资源限制主要给 production compose 使用；调大前先确认宿主机 CPU/内存有余量。
TOKENINSIDE_POSTGRES_CPUS=1.0
TOKENINSIDE_POSTGRES_MEM_LIMIT=768m
TOKENINSIDE_POSTGRES_MEM_RESERVATION=512m
TOKENINSIDE_APP_CPUS=0.75
TOKENINSIDE_APP_MEM_LIMIT=768m
TOKENINSIDE_APP_MEM_RESERVATION=512m
TOKENINSIDE_REDIS_MAXMEMORY=64mb
TOKENINSIDE_REDIS_CPUS=0.15
TOKENINSIDE_REDIS_MEM_LIMIT=128m
TOKENINSIDE_REDIS_MEM_RESERVATION=64m

# 飞书自建应用 App ID。
# 用途：飞书 OAuth 免登、tenant_access_token、H5 JSAPI 登录。
# 获取方式：飞书开放平台 -> 对应自建应用 -> 凭证与基础信息 -> App ID。
FEISHU_APP_ID=replace-with-feishu-app-id

# 飞书自建应用 App Secret。
# 用途：服务端获取飞书 tenant_access_token 和 OAuth token。
# 获取方式：飞书开放平台 -> 对应自建应用 -> 凭证与基础信息 -> App Secret。
# 注意：只允许服务端保存，不要暴露给前端。
FEISHU_APP_SECRET=replace-with-feishu-app-secret

# 飞书审批定义 code（旧原生审批实例备用路径）。
# 用途：当前主链路已经使用飞书交互卡片审批；该变量仅在保留旧飞书原生审批实例备用路径时使用。
# 获取方式：飞书审批后台创建审批定义后，在审批定义/接口配置中查看 approval_code；不用旧审批实例可留空。
FEISHU_APPROVAL_CODE_TOKEN_REQUEST=replace-with-approval-code-or-leave-empty

# 飞书事件回调 Verification Token。
# 用途：校验 `/api/feishu/events` 收到的飞书事件/卡片回调确实来自该应用。
# 获取方式：飞书开放平台 -> 对应应用 -> 开发配置 -> 事件与回调 -> 加密策略 / Verification Token。
FEISHU_APPROVAL_EVENT_VERIFICATION_TOKEN=replace-with-feishu-event-verification-token

# 飞书事件回调 Encrypt Key。
# 用途：解密飞书事件订阅和卡片回调中的 `{ encrypt }` 加密体。
# 获取方式：飞书开放平台 -> 对应应用 -> 开发配置 -> 事件与回调 -> 加密策略 / Encrypt Key。
# 注意：如果飞书后台开启了事件加密，这里必须填写同一个值。
FEISHU_APPROVAL_EVENT_ENCRYPT_KEY=replace-with-feishu-event-encrypt-key

# 系统管理员飞书 open_id 列表，逗号分隔。
# 用途：
# - 初始化 TokenInside 系统管理员。
# - 当用户不属于任何组织、部门主管无法识别、部门负责人缺失时，审批请求会兜底发送给系统管理员。
# - 系统管理员可以查看全部管理员并指派管理员。
# 获取方式：
# - 让目标管理员先通过飞书进入 TokenInside，后台/接口会记录 open_id。
# - 或在飞书开放平台通讯录接口、飞书用户详情调试结果中查到该用户 open_id。
# 注意：这是飞书 OAuth 之后的授权白名单，不是新的登录方式。
# 示例：TOKENINSIDE_SYSTEM_ADMIN_OPEN_IDS=ou_xxx,ou_yyy
TOKENINSIDE_SYSTEM_ADMIN_OPEN_IDS=

# 旧版全局管理员变量，保留兼容。
# 用途：兼容已有部署里的 TOKENINSIDE_ADMIN_OPEN_IDS。
# 获取方式：新部署不要再使用，改填 TOKENINSIDE_SYSTEM_ADMIN_OPEN_IDS。
TOKENINSIDE_ADMIN_OPEN_IDS=

# NewAPI 服务端地址。
# 用途：TokenInside 后端创建/禁用/调额 NewAPI token，并代理 `/v1/*` 请求。
# 获取方式：填写已部署 NewAPI 的 HTTPS 地址，例如 https://new-api.example.com。
# 注意：这是后端访问地址，不要把 NewAPI 直连地址展示给普通用户。
NEWAPI_BASE_URL=https://new-api.example.com

# NewAPI 控制面请求硬超时，单位毫秒；不影响 `/v1/*` 长响应和流式代理。
NEWAPI_REQUEST_TIMEOUT_MS=90000

# NewAPI 控制面用户 ID。
# 用途：调用 NewAPI `/api/token` 等用户态 token 管理接口时，作为 NewAPI 承载用户身份。
# 获取方式：登录 NewAPI 后台，在用户列表、数据库或接口调试中确认承载用户的 ID。
NEWAPI_CONTROL_USER_ID=replace-with-newapi-control-user-id

# NewAPI 系统级访问凭据。
# 用途：服务端调用 NewAPI 控制面 API 的系统级凭据。
# 获取方式：由 NewAPI 后台或部署方提供。
# 注意：如使用 access token，可留空本项并填写下面对应 token。
NEWAPI_SYSTEM_AK=replace-with-newapi-system-ak

# NewAPI 普通 access token。
# 用途：部分 NewAPI 部署用该 token 调控制面；未使用可留空。
# 获取方式：NewAPI 后台生成或部署方提供。未使用请留空。
NEWAPI_ACCESS_TOKEN=

# NewAPI 管理员 access token。
# 用途：部分 NewAPI 部署用管理员 token 调控制面；未使用可留空。
# 获取方式：NewAPI 后台生成或部署方提供。未使用请留空。
NEWAPI_ADMIN_ACCESS_TOKEN=

# NewAPI 内部额度单位倍率。
# 用途：TokenInside 展示额度和 NewAPI remain_quota 内部单位换算。
# 获取方式：按 NewAPI 部署配置确认；upstream 默认 1 展示额度 = 500000 内部 quota。
NEWAPI_QUOTA_PER_UNIT=500000

# 是否开启真实月度账期重置。
# 用途：控制 `/api/admin/billing/monthly-reset` 是否允许非 dry-run 执行并真实修改 NewAPI active token quota。
# 获取方式：默认 false；只有完成生产数据库备份/恢复验证、维护窗口确认后才改为 true。
TOKENINSIDE_MONTHLY_RESET_ENABLED=false

# 本地 mock NewAPI 开关。
# 用途：本地临时开发时跳过真实 NewAPI 调用。
# 获取方式：生产和共享测试环境必须 false；只有本地一次性测试可设 true。
TOKENINSIDE_MOCK_NEWAPI=false

# 可选运维脚本变量。
# 用途：这些变量只影响 production compose 覆盖、数据库导入/备份/恢复、生产拉镜像辅助脚本。
# 获取方式：多数情况保持默认；只在对应脚本命令说明要求时临时改为 true 或填入命令包装器。

# production compose 读取的 env 文件名；默认使用当前 `.env`。
TOKENINSIDE_ENV_FILE=.env

# JSON -> PostgreSQL 导入替换确认；默认 false，执行替换导入时优先使用命令行 --confirm-replace。
TOKENINSIDE_CONFIRM_REPLACE_IMPORT=false

# PostgreSQL 备份/恢复脚本使用的容器名、应用容器名和备份目录。
TOKENINSIDE_PG_CONTAINER=tokeninside-postgres
TOKENINSIDE_APP_CONTAINER=tokeninside
TOKENINSIDE_BACKUP_DIR=./backups/postgres

# PostgreSQL 恢复保护开关；恢复生产库时必须手动改为 true 或在命令前临时设置。
TOKENINSIDE_CONFIRM_RESTORE=false
# 恢复前是否停止应用容器；生产恢复可按维护窗口设为 true。
TOKENINSIDE_RESTORE_STOP_APP=false
# 是否跳过恢复前自动备份；生产默认不要跳过。
TOKENINSIDE_SKIP_PRE_RESTORE_BACKUP=false

# Docker/systemctl 命令包装器；生产机如需要 sudo，可临时设置为 `sudo -n docker` / `sudo -n systemctl`。
TOKENINSIDE_DOCKER_CMD=
TOKENINSIDE_SYSTEMCTL_CMD=

# 生产拉镜像辅助脚本的 mihomo 服务名和启动等待秒数。
TOKENINSIDE_MIHOMO_SERVICE=mihomo.service
TOKENINSIDE_MIHOMO_START_WAIT_SECONDS=10
