# TokenInside 300 mixed + 20 async local architecture checkpoint (2026-07-16).
#
# This profile is NOT an accepted production profile. A 15s+15s sustained smoke
# passed forwarding and exact billing but did not keep mixed operations under
# 10 seconds. It is retained as the conservative baseline for the next
# architecture iteration; do not describe it as having passed the formal
# 5-minute + 10-minute acceptance.
#
# This is an opt-in local test profile, not a safe default for every host.
# It targets one TokenInside process with the app and PostgreSQL sharing the same
# two logical CPUs; app memory is 1 GiB and PostgreSQL memory is 768 MiB.
#
# PostgreSQL connection budget for the acceptance harness:
#   usable PostgreSQL connections: 96 - 8 reserved = 88
#   TokenInside pools: 60 business + 8 control + 5 lock = 73
#   external test pools: 4 observer + 4 async-operation driver = 8
#   remaining headroom: 88 - 73 - 8 = 7 connections
# Do not increase a pool without recalculating every app replica and external
# observer/driver connection against the usable PostgreSQL connection count.

DATABASE_POOL_MAX=60
DATABASE_CONTROL_POOL_MAX=8
DATABASE_LOCK_POOL_MAX=5

TOKENINSIDE_PROXY_CONCURRENCY_MAX=300
TOKENINSIDE_PROXY_QUEUE_TIMEOUT_MS=30000
TOKENINSIDE_PROXY_PREPARATION_CONCURRENCY_MAX=56
TOKENINSIDE_PROXY_PREPARATION_QUEUE_TIMEOUT_MS=30000
TOKENINSIDE_PROXY_PERSISTENCE_CONCURRENCY_MAX=4

TOKENINSIDE_QUOTA_OPERATION_CONCURRENCY_MAX=4
TOKENINSIDE_USAGE_SETTLEMENT_CONCURRENCY_MAX=6

POSTGRES_MAX_CONNECTIONS=96
POSTGRES_SUPERUSER_RESERVED_CONNECTIONS=8
POSTGRES_SHARED_BUFFERS=192MB
POSTGRES_EFFECTIVE_CACHE_SIZE=512MB
POSTGRES_WORK_MEM=2MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_WAL_COMPRESSION=on
POSTGRES_IDLE_IN_TRANSACTION_SESSION_TIMEOUT=30s
POSTGRES_STATEMENT_TIMEOUT=30s
POSTGRES_LOCK_TIMEOUT=5s
POSTGRES_LOG_MIN_DURATION_STATEMENT=1000ms

TOKENINSIDE_POSTGRES_SHM_SIZE=128m
TOKENINSIDE_POSTGRES_CPUS=2.0
TOKENINSIDE_POSTGRES_MEM_LIMIT=768m
TOKENINSIDE_APP_CPUS=2.0
TOKENINSIDE_APP_MEM_LIMIT=1g
