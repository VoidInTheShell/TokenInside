# TokenInside legacy 600 mixed + 20 async local experiment profile (2026-07-15).
#
# Historical evidence only: the active acceptance target is now 300 mixed requests.
# This profile predates the dedicated control pool connection budget and must not
# be deployed as-is. It was measured with one TokenInside process on a local stack:
#   app: 1 CPU / 1 GiB; PostgreSQL: 1 CPU / 768 MiB / 128 MiB shm.
# Any future adaptation must verify the persistent .env, host headroom, and:
#   DATABASE_POOL_MAX + DATABASE_CONTROL_POOL_MAX + DATABASE_LOCK_POOL_MAX
#     + maintenance margin
#     <= POSTGRES_MAX_CONNECTIONS - POSTGRES_SUPERUSER_RESERVED_CONNECTIONS

DATABASE_POOL_MAX=64
DATABASE_CONTROL_POOL_MAX=4
DATABASE_LOCK_POOL_MAX=16

TOKENINSIDE_PROXY_CONCURRENCY_MAX=600
TOKENINSIDE_PROXY_QUEUE_TIMEOUT_MS=30000
TOKENINSIDE_PROXY_PREPARATION_CONCURRENCY_MAX=56
TOKENINSIDE_PROXY_PREPARATION_QUEUE_TIMEOUT_MS=30000
TOKENINSIDE_PROXY_PERSISTENCE_CONCURRENCY_MAX=8

TOKENINSIDE_QUOTA_OPERATION_CONCURRENCY_MAX=2
TOKENINSIDE_USAGE_SETTLEMENT_CONCURRENCY_MAX=6

POSTGRES_MAX_CONNECTIONS=96
POSTGRES_SUPERUSER_RESERVED_CONNECTIONS=8
POSTGRES_SHARED_BUFFERS=192MB
POSTGRES_EFFECTIVE_CACHE_SIZE=512MB
POSTGRES_WORK_MEM=2MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_WAL_COMPRESSION=on
POSTGRES_IDLE_IN_TRANSACTION_SESSION_TIMEOUT=30s
POSTGRES_STATEMENT_TIMEOUT=30s
POSTGRES_LOCK_TIMEOUT=5s
POSTGRES_LOG_MIN_DURATION_STATEMENT=1000ms

TOKENINSIDE_POSTGRES_SHM_SIZE=128m
TOKENINSIDE_POSTGRES_CPUS=1.0
TOKENINSIDE_POSTGRES_MEM_LIMIT=768m
TOKENINSIDE_APP_CPUS=1.0
TOKENINSIDE_APP_MEM_LIMIT=1g
