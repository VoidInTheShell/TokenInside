NODE_ENV=production
HOSTNAME=0.0.0.0
PORT=16878
NEXT_TELEMETRY_DISABLED=1

# Public control-plane URL shown to users and used in client examples.
TOKENINSIDE_PUBLIC_BASE_URL=https://ti.kumiko-love.com

# Required in production. Use a long random string.
TOKENINSIDE_SESSION_SECRET=replace-with-a-random-32-byte-secret

# Persist this path with a Docker volume while the MVP uses the JSON store.
TOKENINSIDE_STORE_PATH=.local-data/tokeninside.json

# Feishu self-built app configuration. Do not expose secrets to the frontend.
FEISHU_APP_ID=replace-with-feishu-app-id
FEISHU_APP_SECRET=replace-with-feishu-app-secret
FEISHU_APPROVAL_CODE_TOKEN_REQUEST=replace-with-approval-code
FEISHU_APPROVAL_EVENT_VERIFICATION_TOKEN=replace-with-event-verification-token
FEISHU_APPROVAL_EVENT_ENCRYPT_KEY=

# NewAPI control-plane endpoint and credentials. Keep these server-side only.
NEWAPI_BASE_URL=https://new-api.550w.link
NEWAPI_CONTROL_USER_ID=replace-with-newapi-control-user-id
NEWAPI_SYSTEM_AK=replace-with-newapi-system-ak-or-control-credential
NEWAPI_ACCESS_TOKEN=
NEWAPI_ADMIN_ACCESS_TOKEN=

# Optional local-only integration switch. Leave disabled outside local testing.
TOKENINSIDE_MOCK_NEWAPI=false
