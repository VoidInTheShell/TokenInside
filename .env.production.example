# TokenInside 生产环境变量示例。
# 常规单机部署优先复制为 `.env`，让 compose 插值和容器 env_file 读取同一个文件。
# 如果必须保留 `.env.production`，启动 production compose 时需要同时指定：
# TOKENINSIDE_ENV_FILE=.env.production docker compose --env-file .env.production -f docker-compose.production.example.yml up -d

# 运行模式：生产环境固定为 production。
NODE_ENV=production
# 服务监听地址：容器内通常保持 0.0.0.0。
HOSTNAME=0.0.0.0
# 服务监听端口：需要与 docker-compose / 反代端口保持一致。
PORT=16878
# 关闭 Next.js 匿名遥测。
NEXT_TELEMETRY_DISABLED=1

# TokenInside 应用镜像：CI/CD 默认发布到 GitHub Container Registry。
# staging 通常使用 ghcr.io/voidintheshell/tokeninside:staging；
# production 通常使用 ghcr.io/voidintheshell/tokeninside:production；
# 回滚或精确部署时使用 ghcr.io/voidintheshell/tokeninside:sha-<commit>。
TOKENINSIDE_IMAGE=ghcr.io/voidintheshell/tokeninside:production

# 对外访问地址：填写用户浏览器访问 TokenInside 的完整域名。
# 获取位置：部署后的公网域名 / BunkerWeb / 反向代理配置，例如 https://ti.example.com。
TOKENINSIDE_PUBLIC_BASE_URL=https://ti.example.com
# 会话签名密钥：用于保护登录态 Cookie，生产环境必须换成长随机字符串。
# 获取方式：本地生成 32 字节以上随机值，例如 PowerShell 执行 `[guid]::NewGuid().ToString("N") + [guid]::NewGuid().ToString("N")`。
TOKENINSIDE_SESSION_SECRET=replace-with-a-long-random-session-secret

# 数据存储后端：生产环境建议使用 postgres。
# 可选值：postgres / json。json 只适合本地开发或临时验证。
TOKENINSIDE_STORE_BACKEND=postgres
# JSON 后端的数据文件路径：使用 postgres 时通常不会读取，保留用于回退。
TOKENINSIDE_STORE_PATH=.local-data/tokeninside.json

# PostgreSQL 数据库名：需要与 compose 中 postgres 服务一致。
POSTGRES_DB=tokeninside
# PostgreSQL 用户名：需要与 compose 中 postgres 服务一致。
POSTGRES_USER=tokeninside
# PostgreSQL 密码：生产环境必须换成强密码。
# 获取方式：手动生成并同时填入 DATABASE_URL。
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
# PostgreSQL 连接串：应用连接数据库使用。
# 获取方式：由 POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB 和 compose 服务名 postgres 组合得到。
DATABASE_URL=postgresql://tokeninside:replace-with-a-strong-postgres-password@postgres:5432/tokeninside
# 数据库连接池最大连接数。
DATABASE_POOL_MAX=10
# 数据库空闲连接回收时间，单位毫秒。
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
# 数据库连接建立超时，单位毫秒。
DATABASE_POOL_CONNECTION_TIMEOUT_MS=5000

# PostgreSQL / TokenInside 调优参数。
# 简单判断方法：
# 1. 2C2G、约 60 人、峰值并发 100 的当前口径，先保持本区默认值。
# 2. 如果 /api/health、日志或压测出现 pool timeout，再小幅增加 DATABASE_POOL_MAX；多 app 副本时按副本数累加，确保 app 总 pool + 5 个维护余量 < POSTGRES_MAX_CONNECTIONS - POSTGRES_SUPERUSER_RESERVED_CONNECTIONS。
# 3. 如果 PG 容器 OOM 或频繁重启，优先降低 DATABASE_POOL_MAX、POSTGRES_WORK_MEM 或 POSTGRES_SHARED_BUFFERS，不要同时增加连接数和 work_mem。
# 4. 如果慢查询增多，先看 POSTGRES_LOG_MIN_DURATION_STATEMENT 打出的 SQL、索引和 NewAPI 上游等待，不要直接加连接数。
# 5. 如果写入后表膨胀、vacuum 跟不上，再调 autovacuum_*；不要关闭 POSTGRES_AUTOVACUUM。

# PostgreSQL 总连接上限；需要覆盖 app pool、维护连接和超级用户预留连接。
POSTGRES_MAX_CONNECTIONS=30
# PostgreSQL 超级用户和维护操作预留连接；不要分配给应用池。
POSTGRES_SUPERUSER_RESERVED_CONNECTIONS=3

# PG 共享缓存；当前 PG 容器 768m 内存口径下默认 256MB。
POSTGRES_SHARED_BUFFERS=256MB
# 优化器缓存估算值，不是实际分配内存；通常按 PG 可用内存和系统缓存估算。
POSTGRES_EFFECTIVE_CACHE_SIZE=768MB
# 单个排序 / hash 操作可用内存；连接数升高时不要同步放大该值。
POSTGRES_WORK_MEM=4MB
# vacuum、建索引等维护任务内存。
POSTGRES_MAINTENANCE_WORK_MEM=64MB

# checkpoint 间隔；写入压力不大时保持 10min，过短会增加刷盘频率。
POSTGRES_CHECKPOINT_TIMEOUT=10min
# checkpoint 平滑刷盘比例；0.9 表示尽量把刷盘分散到周期内。
POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
# WAL 最大保留区间；写入突增时可减少 checkpoint 抖动。
POSTGRES_MAX_WAL_SIZE=512MB
# WAL 最小保留区间；低写入量下避免频繁回收和重建。
POSTGRES_MIN_WAL_SIZE=128MB
# WAL buffer；小型单机场景保持 16MB 即可。
POSTGRES_WAL_BUFFERS=16MB
# WAL 压缩；可用少量 CPU 换磁盘写入和存储空间。
POSTGRES_WAL_COMPRESSION=on

# 是否开启 autovacuum；生产必须保持 on。
POSTGRES_AUTOVACUUM=on
# autovacuum worker 数；2C2G 小机器默认 2，CPU 紧张时不要盲目升高。
POSTGRES_AUTOVACUUM_MAX_WORKERS=2
# autovacuum 唤醒间隔；写入/更新较多时可缩短，但会增加后台负载。
POSTGRES_AUTOVACUUM_NAPTIME=30s
# vacuum 触发比例；表膨胀明显时可降低。
POSTGRES_AUTOVACUUM_VACUUM_SCALE_FACTOR=0.05
# analyze 触发比例；查询计划不稳定或数据变化快时可降低。
POSTGRES_AUTOVACUUM_ANALYZE_SCALE_FACTOR=0.02
# vacuum 最低触发行数；小表更新频繁时保持较低值。
POSTGRES_AUTOVACUUM_VACUUM_THRESHOLD=50
# analyze 最低触发行数；小表变化频繁时保持较低值。
POSTGRES_AUTOVACUUM_ANALYZE_THRESHOLD=50

# 空闲事务最长停留时间；用于清理忘记提交/回滚的事务。
POSTGRES_IDLE_IN_TRANSACTION_SESSION_TIMEOUT=30s
# 单条 SQL 最大执行时间；接口型服务默认 30s，避免长查询拖垮连接池。
POSTGRES_STATEMENT_TIMEOUT=30s
# 等锁超时；避免请求长时间卡在锁等待上。
POSTGRES_LOCK_TIMEOUT=5s
# 慢查询日志阈值；排查慢查询时可临时调低，稳定后恢复。
POSTGRES_LOG_MIN_DURATION_STATEMENT=500ms

# PG 容器共享内存大小；过小可能影响并行查询和内存操作。
TOKENINSIDE_POSTGRES_SHM_SIZE=128m
# 以下资源限制供 production compose 使用；调大前先确认宿主机 CPU/内存有余量。
TOKENINSIDE_POSTGRES_CPUS=1.0
TOKENINSIDE_POSTGRES_MEM_LIMIT=768m
TOKENINSIDE_POSTGRES_MEM_RESERVATION=512m
TOKENINSIDE_APP_CPUS=0.75
TOKENINSIDE_APP_MEM_LIMIT=768m
TOKENINSIDE_APP_MEM_RESERVATION=512m

# 飞书应用 App ID：用于 OAuth 登录、通讯录读取、审批卡片发送。
# 获取位置：飞书开放平台 -> 开发者后台 -> 对应企业自建应用 -> 凭证与基础信息。
FEISHU_APP_ID=replace-with-feishu-app-id
# 飞书应用 App Secret：与 App ID 配套，后端换取 tenant_access_token 使用。
# 获取位置：飞书开放平台 -> 开发者后台 -> 对应企业自建应用 -> 凭证与基础信息。
FEISHU_APP_SECRET=replace-with-feishu-app-secret
# 飞书审批定义 Code：Token 申请 / 额度重置审批使用的 approval_code。
# 获取位置：飞书管理后台 -> 审批 -> 对应审批定义；也可用项目检查脚本读取审批定义列表后填入。
FEISHU_APPROVAL_CODE_TOKEN_REQUEST=replace-with-approval-code-or-leave-empty
# 飞书事件订阅 Verification Token：用于校验飞书回调来源。
# 获取位置：飞书开放平台 -> 对应应用 -> 事件与回调 -> 加密策略 / Verification Token。
FEISHU_APPROVAL_EVENT_VERIFICATION_TOKEN=replace-with-feishu-event-verification-token
# 飞书事件订阅 Encrypt Key：用于解密飞书回调事件。
# 获取位置：飞书开放平台 -> 对应应用 -> 事件与回调 -> 加密策略 / Encrypt Key。
FEISHU_APPROVAL_EVENT_ENCRYPT_KEY=replace-with-feishu-event-encrypt-key
# TokenInside 系统管理员 open_id 列表：全局管理角色的初始化来源，也是找不到部门主管时的审批兜底人。
# 获取位置：飞书开放平台通讯录接口返回的 user.open_id，或通过项目脚本 / 管理后台用户信息确认。
# 填写方式：多个 open_id 用英文逗号分隔，例如 ou_xxx,ou_yyy。生产环境至少填写 1 个。
TOKENINSIDE_SYSTEM_ADMIN_OPEN_IDS=
# 旧变量兼容：历史全局管理员 open_id 列表。
# 新部署请优先使用 TOKENINSIDE_SYSTEM_ADMIN_OPEN_IDS；保留本变量只是为了兼容旧配置。
TOKENINSIDE_ADMIN_OPEN_IDS=

# NewAPI 基础地址：TokenInside 后端调用 NewAPI 的地址。
# 获取位置：NewAPI 服务实际访问地址，例如 https://new-api.example.com。
NEWAPI_BASE_URL=https://new-api.example.com
# NewAPI 控制用户 ID：TokenInside 为飞书用户创建 / 管理 key 时归属到的 NewAPI 用户。
# 获取位置：NewAPI 后台用户列表中的目标用户 ID。
NEWAPI_CONTROL_USER_ID=replace-with-newapi-control-user-id
# NewAPI System AK：NewAPI 的系统访问密钥，用于后端管理级操作。
# 获取位置：NewAPI 后台或部署配置中的 System AK。不要泄露到前端。
NEWAPI_SYSTEM_AK=replace-with-newapi-system-ak
# NewAPI 普通访问令牌：如当前 NewAPI 版本需要 Bearer Token，可填写；只用 System AK 时可留空。
# 获取位置：NewAPI 后台令牌 / API Key 管理页面。
NEWAPI_ACCESS_TOKEN=
# NewAPI 管理访问令牌：如当前 NewAPI 版本区分管理 token，可填写；不区分时可留空。
# 获取位置：NewAPI 后台管理员令牌配置。
NEWAPI_ADMIN_ACCESS_TOKEN=
# NewAPI 额度换算比例：TokenInside 展示账期额度 / 剩余额度时的单位换算。
# 获取方式：按 NewAPI 当前额度单位约定配置，默认 500000。
NEWAPI_QUOTA_PER_UNIT=500000

# 是否启用每月自动重置：true 会启用账期重置任务，false 表示不自动执行。
TOKENINSIDE_MONTHLY_RESET_ENABLED=false
# 是否使用 Mock NewAPI：仅用于本地开发；生产环境必须为 false。
TOKENINSIDE_MOCK_NEWAPI=false

# 可选运维脚本变量：只影响 production compose 覆盖、数据库导入/备份/恢复、生产拉镜像辅助脚本。
# 多数生产部署保持默认；只在对应脚本命令说明要求时临时改为 true 或填入命令包装器。

# production compose 读取的 env 文件名；默认使用当前 `.env`。
TOKENINSIDE_ENV_FILE=.env

# JSON -> PostgreSQL 导入替换确认；默认 false，执行替换导入时优先使用命令行 --confirm-replace。
TOKENINSIDE_CONFIRM_REPLACE_IMPORT=false

# PostgreSQL 备份/恢复脚本使用的容器名、应用容器名和备份目录。
TOKENINSIDE_PG_CONTAINER=tokeninside-postgres
TOKENINSIDE_APP_CONTAINER=tokeninside
TOKENINSIDE_BACKUP_DIR=./backups/postgres

# PostgreSQL 恢复保护开关；恢复生产库时必须手动改为 true 或在命令前临时设置。
TOKENINSIDE_CONFIRM_RESTORE=false
# 恢复前是否停止应用容器；生产恢复可按维护窗口设为 true。
TOKENINSIDE_RESTORE_STOP_APP=false
# 是否跳过恢复前自动备份；生产默认不要跳过。
TOKENINSIDE_SKIP_PRE_RESTORE_BACKUP=false

# Docker/systemctl 命令包装器；生产机如需要 sudo，可临时设置为 `sudo -n docker` / `sudo -n systemctl`。
TOKENINSIDE_DOCKER_CMD=
TOKENINSIDE_SYSTEMCTL_CMD=

# 生产拉镜像辅助脚本的 mihomo 服务名和启动等待秒数。
TOKENINSIDE_MIHOMO_SERVICE=mihomo.service
TOKENINSIDE_MIHOMO_START_WAIT_SECONDS=10
