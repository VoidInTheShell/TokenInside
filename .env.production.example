NODE_ENV=production
HOSTNAME=0.0.0.0
PORT=16878
NEXT_TELEMETRY_DISABLED=1

# Public control-plane URL shown to users and used in client examples.
TOKENINSIDE_PUBLIC_BASE_URL=https://ti.kumiko-love.com

# Required in production. Use a long random string.
TOKENINSIDE_SESSION_SECRET=replace-with-a-random-32-byte-secret

# Store backend. Keep json until the production PostgreSQL database has been migrated and imported.
TOKENINSIDE_STORE_BACKEND=json

# Persist this path with a Docker volume while using the JSON store.
TOKENINSIDE_STORE_PATH=.local-data/tokeninside.json

# PostgreSQL connection string, required when TOKENINSIDE_STORE_BACKEND=postgres.
DATABASE_URL=postgresql://tokeninside:replace-with-password@postgres:5432/tokeninside
# Password consumed by docker-compose.production.example.yml's postgres container.
POSTGRES_PASSWORD=replace-with-postgres-password
# PostgreSQL app pool defaults for the 2C2G production host.
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=5000

# Optional comma-separated Feishu open_id allowlist for platform administrators.
# This is authorization after Feishu OAuth, not a new authentication method.
TOKENINSIDE_ADMIN_OPEN_IDS=

# Feishu self-built app configuration. Do not expose secrets to the frontend.
FEISHU_APP_ID=replace-with-feishu-app-id
FEISHU_APP_SECRET=replace-with-feishu-app-secret
FEISHU_APPROVAL_CODE_TOKEN_REQUEST=replace-with-approval-code
FEISHU_APPROVAL_EVENT_VERIFICATION_TOKEN=replace-with-event-verification-token
FEISHU_APPROVAL_EVENT_ENCRYPT_KEY=

# NewAPI control-plane endpoint and credentials. Keep these server-side only.
NEWAPI_BASE_URL=https://new-api.550w.link
NEWAPI_CONTROL_USER_ID=replace-with-newapi-control-user-id
NEWAPI_SYSTEM_AK=replace-with-newapi-system-ak-or-control-credential
NEWAPI_ACCESS_TOKEN=
NEWAPI_ADMIN_ACCESS_TOKEN=
# NewAPI internal quota unit multiplier. Upstream default is 500000 quota per 1 display unit.
NEWAPI_QUOTA_PER_UNIT=500000

# Monthly billing reset is disabled by default. Enable only after Postgres/backup/ops checks are ready.
TOKENINSIDE_MONTHLY_RESET_ENABLED=false

# Optional local-only integration switch. Leave disabled outside local testing.
TOKENINSIDE_MOCK_NEWAPI=false
