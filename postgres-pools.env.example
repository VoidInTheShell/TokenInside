# Public PostgreSQL connection-budget example for one TokenInside process.
# Keep five maintenance connections free below the usable PostgreSQL limit.
DATABASE_POOL_MAX=8
DATABASE_SETTLEMENT_POOL_MAX=2
DATABASE_CONTROL_POOL_MAX=4
DATABASE_QUOTA_SUBMIT_POOL_MAX=2
DATABASE_LOCK_POOL_MAX=10
POSTGRES_MAX_CONNECTIONS=36
POSTGRES_SUPERUSER_RESERVED_CONNECTIONS=3
